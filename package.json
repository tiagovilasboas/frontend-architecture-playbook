{
  "name": "frontend-architecture-playbook",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "kill-port 5173 && vite",
    "prepare-data:mcp": "cd mcp-server && npm run prepare-data",
    "prebuild": "node scripts/generate-content-manifest.mjs && npm run prepare-data:mcp",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "prepare": "node scripts/prepare-husky.mjs",
    "postinstall": "node scripts/generate-content-manifest.mjs && npm run prepare-data:mcp",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,mdx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@mantine/code-highlight": "^8.1.3",
    "@mantine/core": "^8.1.3",
    "@mantine/hooks": "^8.1.3",
    "@mantine/spotlight": "^8.1.3",
    "@mdx-js/react": "^3.1.0",
    "@mdx-js/rollup": "^3.1.0",
    "@tabler/icons-react": "^3.34.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.23.5",
    "gray-matter": "^4.0.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "react-syntax-highlighter": "^15.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@mdx-js/mdx": "^3.1.0",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "kill-port": "^2.0.1",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4"
  }
}
