{
  "name": "frontend-architecture-playbook-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes the Front-End Architecture Playbook so Cursor (or other MCP clients) can use its content.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
